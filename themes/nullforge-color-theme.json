{
  "$schema": "vscode://schemas/color-theme",
  "name": "Nullforge Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    // editor surfaces
    "editor.background":                          "#f2ece6",
    "editor.foreground":                          "#110e0b",
    "editor.lineHighlightBackground":             "#e8e0d6aa",
    "editor.lineHighlightBorder":                 "#00000000",
    "editor.selectionBackground":                 "#c4622d33",
    "editor.selectionHighlightBackground":        "#c4622d1c",
    "editor.inactiveSelectionBackground":         "#c4622d1c",
    "editor.wordHighlightBackground":             "#c8bfb555",
    "editor.wordHighlightStrongBackground":       "#c8bfb588",
    "editor.findMatchBackground":                 "#c4622d55",
    "editor.findMatchHighlightBackground":        "#c4622d22",
    "editor.hoverHighlightBackground":            "#c8bfb555",
    "editorWhitespace.foreground":                "#c8bfb5",
    "editorIndentGuide.background1":              "#e8e0d6",
    "editorIndentGuide.activeBackground1":        "#c8bfb5",
    "editorLineNumber.foreground":                "#c8bfb5",
    "editorLineNumber.activeForeground":          "#c4622d",
    "editorRuler.foreground":                     "#e8e0d6",
    "editorCursor.foreground":                    "#c4622d",
    "editorCursor.background":                    "#f2ece6",
    "editorBracketMatch.background":              "#c4622d22",
    "editorBracketMatch.border":                  "#c4622d88",
    "editorBracketHighlight.foreground1":         "#c4622d",
    "editorBracketHighlight.foreground2":         "#8f4420",
    "editorBracketHighlight.foreground3":         "#3d5a75",
    "editorBracketHighlight.foreground4":         "#4a7c3a",
    "editorBracketHighlight.foreground5":         "#1a2a3a",
    "editorBracketHighlight.foreground6":         "#6b6058",

    // gutter / overview ruler
    "editorGutter.background":                    "#f2ece6",
    "editorGutter.modifiedBackground":            "#c4622d",
    "editorGutter.addedBackground":               "#4a7c3a",
    "editorGutter.deletedBackground":             "#a13c2a",
    "editorOverviewRuler.border":                 "#e8e0d6",
    "editorOverviewRuler.modifiedForeground":     "#c4622dcc",
    "editorOverviewRuler.addedForeground":        "#4a7c3acc",
    "editorOverviewRuler.deletedForeground":      "#a13c2acc",
    "editorOverviewRuler.errorForeground":        "#a13c2a",
    "editorOverviewRuler.warningForeground":      "#c4622d",
    "editorOverviewRuler.infoForeground":         "#3d5a75",

    // diagnostics
    "editorError.foreground":                     "#a13c2a",
    "editorWarning.foreground":                   "#c4622d",
    "editorInfo.foreground":                      "#3d5a75",

    // activity bar (left rail) — stays dark for brand presence
    "activityBar.background":                     "#0a1420",
    "activityBar.foreground":                     "#f2ece6",
    "activityBar.inactiveForeground":             "#3d5a75",
    "activityBar.activeBackground":               "#1a2a3a",
    "activityBar.activeBorder":                   "#c4622d",
    "activityBar.border":                         "#1a2a3a",
    "activityBarBadge.background":                "#c4622d",
    "activityBarBadge.foreground":                "#f2ece6",

    // sidebar
    "sideBar.background":                         "#e8e0d6",
    "sideBar.foreground":                         "#6b6058",
    "sideBar.border":                             "#c8bfb5",
    "sideBarTitle.foreground":                    "#110e0b",
    "sideBarSectionHeader.background":            "#dcd2c6",
    "sideBarSectionHeader.foreground":            "#110e0b",
    "sideBarSectionHeader.border":                "#c8bfb5",
    "list.activeSelectionBackground":             "#c4622d",
    "list.activeSelectionForeground":             "#f2ece6",
    "list.inactiveSelectionBackground":           "#dcd2c6",
    "list.inactiveSelectionForeground":           "#110e0b",
    "list.hoverBackground":                       "#dcd2c688",
    "list.hoverForeground":                       "#110e0b",
    "list.focusBackground":                       "#dcd2c6",
    "list.focusForeground":                       "#110e0b",
    "list.highlightForeground":                   "#c4622d",
    "list.dropBackground":                        "#c4622d22",

    // tree / git decorations
    "tree.indentGuidesStroke":                    "#c8bfb5",
    "gitDecoration.modifiedResourceForeground":   "#c4622d",
    "gitDecoration.addedResourceForeground":      "#4a7c3a",
    "gitDecoration.deletedResourceForeground":    "#a13c2a",
    "gitDecoration.untrackedResourceForeground":  "#4a7c3a",
    "gitDecoration.ignoredResourceForeground":    "#c8bfb5",
    "gitDecoration.conflictingResourceForeground":"#a13c2a",

    // title bar
    "titleBar.activeBackground":                  "#0a1420",
    "titleBar.activeForeground":                  "#f2ece6",
    "titleBar.inactiveBackground":                "#0a1420",
    "titleBar.inactiveForeground":                "#7a9bb8",
    "titleBar.border":                            "#1a2a3a",
    "menubar.selectionBackground":                "#1a2a3a",
    "menubar.selectionForeground":                "#f2ece6",

    // tabs
    "editorGroupHeader.tabsBackground":           "#e8e0d6",
    "editorGroupHeader.tabsBorder":               "#c8bfb5",
    "editorGroupHeader.border":                   "#c8bfb5",
    "editorGroup.border":                         "#c8bfb5",
    "tab.activeBackground":                       "#f2ece6",
    "tab.activeForeground":                       "#110e0b",
    "tab.activeBorderTop":                        "#c4622d",
    "tab.activeBorder":                           "#f2ece6",
    "tab.inactiveBackground":                     "#e8e0d6",
    "tab.inactiveForeground":                     "#6b6058",
    "tab.hoverBackground":                        "#dcd2c6",
    "tab.hoverForeground":                        "#110e0b",
    "tab.border":                                 "#c8bfb5",
    "tab.unfocusedActiveBorderTop":               "#c8bfb5",

    // breadcrumbs
    "breadcrumb.background":                      "#f2ece6",
    "breadcrumb.foreground":                      "#6b6058",
    "breadcrumb.focusForeground":                 "#110e0b",
    "breadcrumb.activeSelectionForeground":       "#c4622d",
    "breadcrumbPicker.background":                "#fbf6f1",

    // status bar
    "statusBar.background":                       "#c4622d",
    "statusBar.foreground":                       "#f2ece6",
    "statusBar.border":                           "#8f4420",
    "statusBar.noFolderBackground":               "#1a2a3a",
    "statusBar.noFolderForeground":               "#f2ece6",
    "statusBar.debuggingBackground":              "#8f4420",
    "statusBar.debuggingForeground":              "#f2ece6",
    "statusBarItem.hoverBackground":              "#8f422088",
    "statusBarItem.remoteBackground":             "#1a2a3a",
    "statusBarItem.remoteForeground":             "#f2ece6",
    "statusBarItem.errorBackground":              "#a13c2a",
    "statusBarItem.errorForeground":              "#f2ece6",
    "statusBarItem.warningBackground":            "#8f4420",
    "statusBarItem.warningForeground":            "#f2ece6",

    // panel
    "panel.background":                           "#e8e0d6",
    "panel.border":                               "#c8bfb5",
    "panelTitle.activeForeground":                "#c4622d",
    "panelTitle.activeBorder":                    "#c4622d",
    "panelTitle.inactiveForeground":              "#6b6058",
    "panelSectionHeader.background":              "#dcd2c6",

    // terminal
    "terminal.background":                        "#fbf6f1",
    "terminal.foreground":                        "#110e0b",
    "terminal.ansiBlack":                         "#110e0b",
    "terminal.ansiRed":                           "#a13c2a",
    "terminal.ansiGreen":                         "#4a7c3a",
    "terminal.ansiYellow":                        "#c4622d",
    "terminal.ansiBlue":                          "#3d5a75",
    "terminal.ansiMagenta":                       "#8f4420",
    "terminal.ansiCyan":                          "#1a2a3a",
    "terminal.ansiWhite":                         "#f2ece6",
    "terminal.ansiBrightBlack":                   "#6b6058",
    "terminal.ansiBrightRed":                     "#a13c2a",
    "terminal.ansiBrightGreen":                   "#4a7c3a",
    "terminal.ansiBrightYellow":                  "#c4622d",
    "terminal.ansiBrightBlue":                    "#3d5a75",
    "terminal.ansiBrightMagenta":                 "#8f4420",
    "terminal.ansiBrightCyan":                    "#1a2a3a",
    "terminal.ansiBrightWhite":                   "#f2ece6",
    "terminalCursor.background":                  "#f2ece6",
    "terminalCursor.foreground":                  "#c4622d",

    // inputs / dropdowns / buttons
    "input.background":                           "#fbf6f1",
    "input.foreground":                           "#110e0b",
    "input.border":                               "#c8bfb5",
    "input.placeholderForeground":                "#6b6058",
    "inputOption.activeBackground":               "#c4622d33",
    "inputOption.activeBorder":                   "#c4622d",
    "inputOption.activeForeground":               "#110e0b",
    "inputValidation.errorBackground":            "#a13c2a22",
    "inputValidation.errorBorder":                "#a13c2a",
    "inputValidation.warningBackground":          "#c4622d22",
    "inputValidation.warningBorder":              "#c4622d",
    "inputValidation.infoBackground":             "#3d5a7522",
    "inputValidation.infoBorder":                 "#3d5a75",
    "dropdown.background":                        "#fbf6f1",
    "dropdown.foreground":                        "#110e0b",
    "dropdown.border":                            "#c8bfb5",
    "button.background":                          "#c4622d",
    "button.foreground":                          "#f2ece6",
    "button.hoverBackground":                     "#8f4420",
    "button.secondaryBackground":                 "#e8e0d6",
    "button.secondaryForeground":                 "#110e0b",
    "button.secondaryHoverBackground":            "#c8bfb5",
    "checkbox.background":                        "#fbf6f1",
    "checkbox.foreground":                        "#c4622d",
    "checkbox.border":                            "#c8bfb5",

    // quickpick / command palette
    "quickInput.background":                      "#fbf6f1",
    "quickInput.foreground":                      "#110e0b",
    "quickInputTitle.background":                 "#e8e0d6",
    "pickerGroup.foreground":                     "#c4622d",
    "pickerGroup.border":                         "#c8bfb5",

    // scrollbar
    "scrollbar.shadow":                           "#00000000",
    "scrollbarSlider.background":                 "#6b605855",
    "scrollbarSlider.hoverBackground":            "#6b605888",
    "scrollbarSlider.activeBackground":           "#c4622d88",

    // minimap
    "minimap.background":                         "#f2ece6",
    "minimap.selectionHighlight":                 "#c4622da2",
    "minimap.findMatchHighlight":                 "#c4622da2",
    "minimap.errorHighlight":                     "#a13c2a",
    "minimap.warningHighlight":                   "#c4622d",
    "minimapSlider.background":                   "#c8bfb544",
    "minimapSlider.hoverBackground":              "#c8bfb566",
    "minimapSlider.activeBackground":             "#c4622d66",

    // notifications / badges
    "notificationCenter.border":                  "#c8bfb5",
    "notificationCenterHeader.background":        "#e8e0d6",
    "notificationCenterHeader.foreground":        "#110e0b",
    "notifications.background":                   "#fbf6f1",
    "notifications.foreground":                   "#110e0b",
    "notifications.border":                       "#c8bfb5",
    "notificationsErrorIcon.foreground":          "#a13c2a",
    "notificationsWarningIcon.foreground":        "#c4622d",
    "notificationsInfoIcon.foreground":           "#3d5a75",
    "badge.background":                           "#c4622d",
    "badge.foreground":                           "#f2ece6",
    "progressBar.background":                     "#c4622d",

    // peek / diff / merge
    "peekView.border":                            "#c4622d",
    "peekViewEditor.background":                  "#e8e0d6",
    "peekViewEditor.matchHighlightBackground":    "#c4622d44",
    "peekViewResult.background":                  "#fbf6f1",
    "peekViewResult.selectionBackground":         "#c4622d44",
    "peekViewResult.selectionForeground":         "#110e0b",
    "peekViewTitle.background":                   "#e8e0d6",
    "peekViewTitleLabel.foreground":              "#110e0b",
    "peekViewTitleDescription.foreground":        "#6b6058",
    "diffEditor.insertedTextBackground":          "#4a7c3a22",
    "diffEditor.removedTextBackground":           "#a13c2a22",
    "diffEditorGutter.insertedLineBackground":    "#4a7c3a22",
    "diffEditorGutter.removedLineBackground":     "#a13c2a22",
    "merge.currentHeaderBackground":              "#c4622d66",
    "merge.currentContentBackground":             "#c4622d22",
    "merge.incomingHeaderBackground":             "#3d5a7588",
    "merge.incomingContentBackground":            "#3d5a7544",

    // misc focus + borders
    "focusBorder":                                "#c4622d",
    "foreground":                                 "#110e0b",
    "descriptionForeground":                      "#6b6058",
    "errorForeground":                            "#a13c2a",
    "icon.foreground":                            "#6b6058",
    "widget.shadow":                              "#11000022",
    "selection.background":                       "#c4622d40",
    "textLink.foreground":                        "#c4622d",
    "textLink.activeForeground":                  "#8f4420",
    "textBlockQuote.background":                  "#e8e0d6",
    "textBlockQuote.border":                      "#c4622d",
    "textCodeBlock.background":                   "#e8e0d6",
    "textPreformat.foreground":                   "#8f4420",
    "textSeparator.foreground":                   "#c8bfb5"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6b6058", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#8f4420" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Numbers / constants",
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": { "foreground": "#8f4420" }
    },
    {
      "name": "Booleans / null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation"],
      "settings": { "foreground": "#3d5a75" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#1a2a3a" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#3d5a75", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#110e0b" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.object-literal.key", "support.type.property-name"],
      "settings": { "foreground": "#3d5a75" }
    },
    {
      "name": "Types / classes",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "storage.type.class"],
      "settings": { "foreground": "#8f4420" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.other.inherited-class", "entity.name.type.interface"],
      "settings": { "foreground": "#8f4420", "fontStyle": "italic" }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#8f4420", "fontStyle": "italic" }
    },
    {
      "name": "Markup headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#c4622d", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#110e0b", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#110e0b", "fontStyle": "italic" }
    },
    {
      "name": "Markup link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#c4622d", "fontStyle": "underline" }
    },
    {
      "name": "Markup code",
      "scope": ["markup.inline.raw", "markup.raw.block"],
      "settings": { "foreground": "#8f4420" }
    },
    {
      "name": "Markup quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6b6058", "fontStyle": "italic" }
    },
    {
      "name": "Markup added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#4a7c3a" }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#a13c2a" }
    },
    {
      "name": "Markup changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#a13c2a", "fontStyle": "underline" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#8f4420" }
    },
    {
      "name": "Embedded punctuation (JSX braces)",
      "scope": ["punctuation.section.embedded", "meta.brace"],
      "settings": { "foreground": "#3d5a75" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#8f4420", "fontStyle": "italic" }
    },
    {
      "name": "TOML / INI keys",
      "scope": ["entity.name.tag.toml", "keyword.key.toml"],
      "settings": { "foreground": "#c4622d" }
    }
  ]
}
